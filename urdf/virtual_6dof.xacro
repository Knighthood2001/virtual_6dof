<?xml version="1.0" encoding="UTF-8"?>
<robot name="virtual_6dof" xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="virtual_6dof"
    params="parent_link end_link prefix
            *origin_offset *end_effector_offset">

    <!-- 平台基座连杆 -->
    <link name="${prefix}_virtual_6dof_base_link">
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_dark_gray"><color rgba="0.3 0.3 0.3 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
    </link>

    <joint name="${prefix}_virtual_6dof_base_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="${prefix}_virtual_6dof_base_link"/>
      <xacro:insert_block name="origin_offset"/>
    </joint>

    <!-- ===== 6 自由度关节链（所有名字都加 ${prefix}_ 前缀） ===== -->
    <joint name="${prefix}_virtual_6dof_x_trans_joint" type="prismatic">
      <parent link="${prefix}_virtual_6dof_base_link"/>
      <child  link="${prefix}_virtual_6dof_x_trans_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="1 0 0"/>
      <limit lower="-50.0" upper="50.0" effort="100" velocity="0.5"/>
      <dynamics damping="15.0" friction="1.0"/>
    </joint>
    <link name="${prefix}_virtual_6dof_x_trans_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_x_axis"><color rgba="1 0.2 0.2 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_y_trans_joint" type="prismatic">
      <parent link="${prefix}_virtual_6dof_x_trans_link"/>
      <child  link="${prefix}_virtual_6dof_y_trans_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="0 1 0"/>
      <limit lower="-50.0" upper="50.0" effort="100" velocity="0.5"/>
      <dynamics damping="15.0" friction="1.0"/>
    </joint>
    <link name="${prefix}_virtual_6dof_y_trans_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_y_axis"><color rgba="0.2 1 0.2 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_z_trans_joint" type="prismatic">
      <parent link="${prefix}_virtual_6dof_y_trans_link"/>
      <child  link="${prefix}_virtual_6dof_z_trans_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="0 0 1"/>
      <limit lower="-50.0" upper="50.0" effort="100" velocity="0.5"/>
      <dynamics damping="15.0" friction="1.0"/>
    </joint>
    <link name="${prefix}_virtual_6dof_z_trans_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_z_axis"><color rgba="0.2 0.2 1 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_roll_joint" type="revolute">
      <parent link="${prefix}_virtual_6dof_z_trans_link"/>
      <child  link="${prefix}_virtual_6dof_roll_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="1 0 0"/>
      <limit lower="-3.14" upper="3.14" effort="30" velocity="2.0"/>
      <dynamics damping="15.0" friction="1.0"/>
    </joint>
    <link name="${prefix}_virtual_6dof_roll_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_roll"><color rgba="1 0.5 0 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_pitch_joint" type="revolute">
      <parent link="${prefix}_virtual_6dof_roll_link"/>
      <child  link="${prefix}_virtual_6dof_pitch_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="30" velocity="2.0"/>
      <dynamics damping="8.0" friction="0.3"/>
    </joint>
    <link name="${prefix}_virtual_6dof_pitch_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_pitch"><color rgba="1 0.5 0 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_yaw_joint" type="revolute">
      <parent link="${prefix}_virtual_6dof_pitch_link"/>
      <child  link="${prefix}_virtual_6dof_yaw_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis  xyz="0 0 1"/>
      <limit lower="-3.14" upper="3.14" effort="30" velocity="2.0"/>
      <dynamics damping="8.0" friction="0.3"/>
    </joint>
    <link name="${prefix}_virtual_6dof_yaw_link">
      <visual>
        <geometry><box size="0 0 0"/></geometry>
        <material name="${prefix}_yaw"><color rgba="1 0.5 0 1"/></material>
      </visual>
      <collision><geometry><box size="0 0 0"/></geometry></collision>
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
      </inertial>
    </link>

    <joint name="${prefix}_virtual_6dof_end_effector_joint" type="fixed">
      <parent link="${prefix}_virtual_6dof_yaw_link"/>
      <child  link="${end_link}"/>
      <xacro:insert_block name="end_effector_offset"/>
    </joint>

    <!-- ===== 传动装置（名字也要加前缀） ===== -->
    <transmission name="${prefix}_virtual_6dof_x_trans_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_x_trans_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_x_trans_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    <transmission name="${prefix}_virtual_6dof_y_trans_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_y_trans_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_y_trans_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    <transmission name="${prefix}_virtual_6dof_z_trans_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_z_trans_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_z_trans_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    <transmission name="${prefix}_virtual_6dof_roll_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_roll_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_roll_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    <transmission name="${prefix}_virtual_6dof_pitch_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_pitch_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_pitch_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>
    <transmission name="${prefix}_virtual_6dof_yaw_joint_trans">
      <type>transmission_interface/SimpleTransmission</type>
      <joint name="${prefix}_virtual_6dof_yaw_joint">
        <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      </joint>
      <actuator name="${prefix}_virtual_6dof_yaw_joint_motor">
        <mechanicalReduction>1</mechanicalReduction>
      </actuator>
    </transmission>

  </xacro:macro>
</robot>